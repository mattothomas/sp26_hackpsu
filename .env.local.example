# Copy this file to .env.local and fill in your values before running

# Gemini API (Google AI Studio - free tier works)
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice ID from ElevenLabs voice library (pick an aggressive male voice)
# Recommended: "ErXwobaYiN019PkySvjV" (Antoni) or browse at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=ErXwobaYiN019PkySvjV

# Presage SmartSpectra (biometric SDK)
# NEXT_PUBLIC_ prefix required — this runs in the browser
NEXT_PUBLIC_PRESAGE_KEY=your_presage_api_key_here
